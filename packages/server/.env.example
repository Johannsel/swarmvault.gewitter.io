# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://swarmvault:swarmvault_dev_password@localhost:5432/swarmvault"

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── JWT ────────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET="CHANGE_ME_USE_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS_LONG_ABCDEF12"
JWT_EXPIRY="7d"

# ── Chunk relay temp storage (local path used during upload/download relay) ────
CHUNK_TEMP_DIR="/tmp/swarmvault-chunks"

# ── Reward scheduler ──────────────────────────────────────────────────────────
# Cron expression for the reward snapshot job (default: every hour)
REWARD_CRON="0 * * * *"
