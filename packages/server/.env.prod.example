# ── Production environment — fill these in before deploying ───────────────────
# Copy to .env.prod and NEVER commit the filled-in version.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Database (matches docker-compose.prod.yml)
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD
DATABASE_URL=postgresql://swarmvault:CHANGE_ME_STRONG_RANDOM_PASSWORD@postgres:5432/swarmvault

# Redis
REDIS_URL=redis://redis:6379

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_BASE64_64
JWT_EXPIRY=7d

# Misc
CHUNK_TEMP_DIR=/tmp/swarmvault-chunks
REWARD_CRON=0 * * * *

# docker-compose.prod.yml templating
DOMAIN=api.swarmvault.gewitter.io
ACME_EMAIL=your@email.com
