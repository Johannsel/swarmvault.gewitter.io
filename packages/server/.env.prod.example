# ── Production environment reference ─────────────────────────────────────────
# In production, secrets (JWT_SECRET, DATABASE_URL, REDIS_URL) are injected by
# docker-entrypoint.sh from Docker secrets files in .secrets/*.txt
# Non-secret vars are set directly in docker-compose.prod.yml — you do NOT need
# a .env file on the production server.
#
# This file is kept only as a reference for what each variable does.

NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Set via Docker secret — .secrets/jwt_secret.txt
# Generate with: openssl rand -base64 64 | tr -d '\n' > .secrets/jwt_secret.txt
JWT_SECRET=<from docker secret>
JWT_EXPIRY=7d

CHUNK_TEMP_DIR=/tmp/swarmvault-chunks
REWARD_CRON=0 * * * *
