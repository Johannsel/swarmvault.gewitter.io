{
  "name": "SwarmVault Server",
  "dockerComposeFile": "../packages/server/docker-compose.yml",
  "service": "server",
  "workspaceFolder": "/workspace",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "20",
      "nvmVersion": "latest"
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "Prisma.prisma",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "ms-azuretools.vscode-docker"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "zsh"
      }
    }
  },

  "postCreateCommand": "npm install -g pnpm && pnpm install && cd packages/server && pnpm prisma:generate",

  "forwardPorts": [3000, 5432, 6379],
  "portsAttributes": {
    "3000": { "label": "SwarmVault API" },
    "5432": { "label": "PostgreSQL" },
    "6379": { "label": "Redis" }
  },

  "remoteUser": "node"
}
